# Copy to .env and set strong secrets before `docker compose up`
#   cp .env.example .env

# --- Required secrets ---
JWT_SECRET=change_me_to_a_long_random_string_min_16_chars
POSTGRES_PASSWORD=change_me_strong_db_password

# --- Database ---
POSTGRES_DB=geoflux
POSTGRES_USER=geoflux_user
POSTGRES_PORT=5432

# --- Redis ---
REDIS_PORT=6379

# --- App ---
NODE_ENV=production
BACKEND_PORT=4000
FRONTEND_PORT=80
CORS_ORIGINS=http://localhost:5173,http://localhost
FRONTEND_URL=http://localhost
