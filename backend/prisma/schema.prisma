generator client {
  provider        = "prisma-client-js"
  output          = "./generated/prisma"
  previewFeatures = ["postgresqlExtensions"]
}

datasource db {
  provider   = "postgresql"
  extensions = [postgis]
}

model User {
  id         String      @id @default(uuid())
  email      String      @unique
  password   String
  name       String?
  datasets   Dataset[]
  workspaces Workspace[]
  createdAt  DateTime    @default(now())
  updatedAt  DateTime    @updatedAt
}

model Dataset {
  id        String    @id @default(uuid())
  name      String
  color     String
  type      String    @default("points")
  features  Feature[]
  user      User?     @relation(fields: [userId], references: [id])
  userId    String?
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt
}

model Feature {
  id        String    @id @default(uuid())
  dataset   Dataset   @relation(fields: [datasetId], references: [id], onDelete: Cascade)
  datasetId String
  geometry  Unsupported("geometry(Geometry, 4326)")
  properties Json
  value      Float?
  category   String?
  timestamp  DateTime?
  createdAt  DateTime  @default(now())

  @@index([datasetId])
  @@index([geometry], map: "feature_geometry_idx", type: Gist)
  @@index([datasetId, value])
  @@index([datasetId, category])
  @@index([datasetId, timestamp])
}

model Workspace {
  id        String   @id @default(uuid())
  name      String
  config    Json     // Stores map position, active layers, etc.
  isPublic  Boolean  @default(false)
  user      User     @relation(fields: [userId], references: [id])
  userId    String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}
